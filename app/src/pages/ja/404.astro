---
import DocLayout from "@layouts/DocLayout.astro";
import { t, type Locale } from "@i18n/index";

const locale: Locale = "ja";
const base = import.meta.env.BASE_URL;
const homeHref = `${base}ja/`;
---

<DocLayout
  title={t("errors.404.pageTitle", locale)}
  description={t("errors.404.pageDesc", locale)}
  locale={locale}
>
  <div id="page-404" class="sidebar-offset">
    <div class="error-page">
      <div class="error-code">404</div>
      <h1 class="error-title">{t("errors.404.title", locale)}</h1>
      <p class="error-desc">{t("errors.404.desc", locale)}</p>
      <div class="error-actions">
        <a href={homeHref} class="error-link"
          >{t("errors.404.returnHome", locale)}</a
        >
        <a
          href="javascript:history.back()"
          class="error-link error-link--secondary"
          >{t("errors.404.goBack", locale)}</a
        >
      </div>
    </div>
  </div>
</DocLayout>
