---
import DocLayout from "@layouts/DocLayout.astro";
import CategoryNode from "@components/CategoryNode.astro";
import { getNavTree } from "@utils/collections";
import { t, type Locale } from "@i18n/index";

const locale: Locale = "ja";
const navTree = await getNavTree(locale);
const siteName = t("site.name", locale);
const heroDescription = t("site.description", locale);
---

<DocLayout locale={locale}>
  <div id="page-home" class="sidebar-offset">
    <div class="home-page">
      <div class="home-hero">
        <h1>{siteName}</h1>
        <p>{heroDescription}</p>
      </div>

      <div class="category-grid">
        {
          navTree.map((category) => (
            <section class="category-card">
              <span class="category-card-corner-tr" />
              <span class="category-card-corner-bl" />
              <h2>{category.label}</h2>
              <ul>
                {(category.children ?? []).map((child) => (
                  <CategoryNode node={child} />
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </div>
</DocLayout>
