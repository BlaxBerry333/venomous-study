---
import DocLayout from "@layouts/DocLayout.astro";
import LegionShowcase from "@components/LegionShowcase.astro";
import { t, type Locale } from "@i18n/index";

const locale: Locale = "zh";
const siteName = t("site.name", locale);
const heroDescription = t("site.description", locale);
---

<DocLayout locale={locale}>
  <div id="page-home" class="sidebar-offset">
    <div class="home-page">
      <div class="home-hero">
        <h1>{siteName}</h1>
        <p>{heroDescription}</p>
      </div>

      <LegionShowcase locale={locale} />
    </div>
  </div>
</DocLayout>
