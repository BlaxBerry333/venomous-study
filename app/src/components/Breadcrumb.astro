---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {
      crumbs.map((crumb, i) => {
        const isLast = i === crumbs.length - 1;
        return (
          <li>
            {i > 0 && <span class="breadcrumb-separator">/</span>}
            {crumb.href ? (
              <a href={crumb.href}>{crumb.label}</a>
            ) : isLast ? (
              <span class="breadcrumb-current" aria-current="page">
                {crumb.label}
              </span>
            ) : (
              <span class="breadcrumb-segment">{crumb.label}</span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  /* BC1-BC7: Matches mockup.html L369-390 exactly */
  .breadcrumb {
    margin-bottom: var(--space-6);
  }
  .breadcrumb ol {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
  }
  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  .breadcrumb a {
    color: var(--color-text-secondary);
    padding: var(--space-1);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .breadcrumb a:hover {
    color: var(--color-primary);
  }
  .breadcrumb-separator {
    color: var(--color-text-muted);
  }
  .breadcrumb-segment {
    color: var(--color-text-secondary);
  }
  .breadcrumb-current {
    color: var(--color-primary);
    font-weight: var(--font-weight-medium);
  }

  /* R768-10: <768px breadcrumb scroll */
  @media (max-width: 767px) {
    .breadcrumb ol {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: var(--space-1);
    }
  }
</style>
