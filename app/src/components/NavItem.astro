---
import type { NavNode } from "@utils/collections";
// Self-import aliased to enable arbitrary-depth recursive rendering
// without colliding with the filename-derived component identifier.
import Self from "@components/NavItem.astro";

interface Props {
  items: NavNode[];
  currentPath: string;
  ariaLabel?: string;
  depth?: number;
}

const { items, currentPath, ariaLabel, depth = 0 } = Astro.props;

function isActive(href: string | undefined, current: string): boolean {
  if (!href) return false;
  const normalizedHref = href.replace(/\/$/, "");
  const normalizedCurrent = current.replace(/\/$/, "");
  return normalizedHref === normalizedCurrent;
}

const isRoot = depth === 0;
const listClass = isRoot
  ? "sidebar-list"
  : `nav-children${depth > 1 ? " nav-children--nested" : ""}`;
const listStyle = isRoot ? undefined : `--nav-depth: ${depth};`;
---

{
  isRoot ? (
    <nav class="sidebar-nav" aria-label={ariaLabel ?? "Documentation"}>
      <ul class={listClass}>
        {items.map((item) => (
          <li class="nav-item">
            {item.isDirectory && depth === 0 ? (
              <>
                <span class="nav-group-label">{item.label}</span>
                {item.children && item.children.length > 0 && (
                  <Self
                    items={item.children}
                    currentPath={currentPath}
                    depth={1}
                  />
                )}
              </>
            ) : item.isDirectory ? (
              <>
                {item.href ? (
                  <a
                    class={`nav-link nav-dir-link${isActive(item.href, currentPath) ? " active" : ""}`}
                    href={item.href}
                    {...(isActive(item.href, currentPath)
                      ? { "aria-current": "page" as const }
                      : {})}
                  >
                    {item.label}
                  </a>
                ) : (
                  <span class="nav-link nav-dir-link" aria-disabled="true">
                    {item.label}
                  </span>
                )}
                {item.children && item.children.length > 0 && (
                  <Self
                    items={item.children}
                    currentPath={currentPath}
                    depth={depth + 1}
                  />
                )}
              </>
            ) : (
              <a
                class={`nav-link${isActive(item.href, currentPath) ? " active" : ""}`}
                href={item.href}
                {...(isActive(item.href, currentPath)
                  ? { "aria-current": "page" as const }
                  : {})}
              >
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  ) : (
    <ul class={listClass} style={listStyle}>
      {items.map((item) => (
        <li class="nav-item">
          {item.isDirectory ? (
            <>
              {item.href ? (
                <a
                  class={`nav-link nav-dir-link${isActive(item.href, currentPath) ? " active" : ""}`}
                  href={item.href}
                  {...(isActive(item.href, currentPath)
                    ? { "aria-current": "page" as const }
                    : {})}
                >
                  {item.label}
                </a>
              ) : (
                <span class="nav-link nav-dir-link" aria-disabled="true">
                  {item.label}
                </span>
              )}
              {item.children && item.children.length > 0 && (
                <Self
                  items={item.children}
                  currentPath={currentPath}
                  depth={depth + 1}
                />
              )}
            </>
          ) : (
            <a
              class={`nav-link${isActive(item.href, currentPath) ? " active" : ""}`}
              href={item.href}
              {...(isActive(item.href, currentPath)
                ? { "aria-current": "page" as const }
                : {})}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  )
}

<style>
  /* SN1-SN7: Matches mockup.html L318-358 exactly */
  .sidebar-nav {
    font-size: var(--font-size-sm);
  }
  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .nav-item {
    display: flex;
    flex-direction: column;
  }
  .nav-link {
    display: flex;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
    border-left: var(--border-width-accent) solid transparent;
    min-height: 44px;
  }
  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--color-primary);
    background: var(--color-surface);
    border-left-color: var(--color-primary);
  }
  /* Directory nodes render as nav-link but may not have an href; keep hover
     subtle when disabled so users don't expect navigation. */
  .nav-link.nav-dir-link[aria-disabled="true"] {
    cursor: default;
    color: var(--color-text);
  }
  .nav-link.nav-dir-link[aria-disabled="true"]:hover {
    background: transparent;
  }
  /* Group label sits to the left of the nav items to create visual hierarchy
     without indenting children, so children stay aligned with sibling controls
     (e.g. the legion selector) in the sidebar. */
  .nav-group-label {
    display: block;
    padding: var(--space-2) 0;
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-transform: capitalize;
    margin-top: var(--space-3);
  }
  .nav-children {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  /* Deeper levels get progressive indent driven by --nav-depth. Each additional
     depth adds one unit of --space-3 left padding on the link itself. */
  .nav-children--nested {
    padding-left: calc((var(--nav-depth, 1) - 1) * var(--space-3));
  }
</style>
