---
import { MAX_NAV_DEPTH, type NavNode } from "@utils/collections";
// Self-import aliased to enable arbitrary-depth recursive rendering.
import Self from "@components/CategoryNode.astro";

interface Props {
  node: NavNode;
}

const { node } = Astro.props;

// Depth derived from the slug path itself (L2=2 segments, L3=3, L4=4).
// Homepage truncates the category grid at L3 — L3 directory nodes render
// their label/href but do NOT expand their L4 children. (The sidebar still
// shows L4 contextually; that rule lives in NavItem.astro.)
const depthByPath = node.path.split("/").filter((s) => s.length > 0).length;
const renderChildren = depthByPath < 3 && depthByPath < MAX_NAV_DEPTH;
---

{
  node.isDirectory ? (
    <li>
      {node.href ? (
        <a class="sub-category sub-category-link" href={node.href}>
          {node.label}
        </a>
      ) : (
        <span class="sub-category">{node.label}</span>
      )}
      {renderChildren && node.children && node.children.length > 0 && (
        <ul class="sub-doc-list">
          {node.children.map((child) => (
            <Self node={child} />
          ))}
        </ul>
      )}
    </li>
  ) : (
    <li>
      <a href={node.href}>{node.label}</a>
    </li>
  )
}
