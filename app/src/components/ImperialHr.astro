    margin: var(--space-8) 0;
  }
  .imperial-hr .hr-line-left {
    flex: 1;
    height: var(--border-width);
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border-light)
    );
  }
  .imperial-hr .hr-line-right {
    flex: 1;
    height: var(--border-width);
    background: linear-gradient(
      to left,
      transparent,
      var(--color-border-light)
    );
  }
  .imperial-hr .hr-diamond {
    width: 8px;
    height: 8px;
    background: var(--color-link-hover);
    transform: rotate(45deg);
    flex-shrink: 0;
  }
</style>
