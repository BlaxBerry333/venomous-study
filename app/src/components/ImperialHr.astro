<div class="imperial-hr" role="separator">
  <div class="hr-line-left"></div>
  <div class="hr-diamond"></div>
  <div class="hr-line-right"></div>
</div>

<style>
  /* HR1-HR5: Matches mockup.html L561-578 exactly */
  .imperial-hr {
    display: flex;
    align-items: center;
