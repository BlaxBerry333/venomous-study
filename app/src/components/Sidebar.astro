---
import LegionSelector from "@components/LegionSelector.astro";
import LanguageSwitcher from "@components/LanguageSwitcher.astro";
import NavItem from "@components/NavItem.astro";
import { getNavTree, toNavPath, getCurrentL3Path } from "@utils/collections";
import { t, type Locale } from "@i18n/index";

interface Props {
  currentPath: string;
  locale: Locale;
}

const { currentPath, locale } = Astro.props;
const base = import.meta.env.BASE_URL;
const localePrefix = locale === "zh" ? "" : "ja/";

const navItems = await getNavTree(locale);
// Pre-normalize the current path once: NavItem compares href (canonical)
// against this canonical nav path on every render. Computing here avoids
// O(n) re-normalization across the recursive tree.
const currentNavPath = toNavPath(currentPath, base, localePrefix);
// Derive the L3 ancestor of the current page in NavNode.path coordinates.
// `null` means "no L3 should expand" (homepage / L1 / L2 index). NavItem
// consumes this to decide whether to render L4 children for a given L3
// directory node. Threshold is `< 3` so L3 index pages also expand — see
// design §3.2 / decision B.
const currentL3Path = getCurrentL3Path(currentNavPath);
---

<aside
  class="doc-sidebar corner-decoration"
  id="sidebar"
  aria-label={t("sidebar.ariaLabel", locale)}
>
  <div class="sidebar-inner scroll-touch">
    <a class="sidebar-home" href={`${base}${localePrefix}`}>
      {t("site.name", locale)}
    </a>
    <LanguageSwitcher currentLocale={locale} currentPath={currentPath} />
    <LegionSelector locale={locale} />
    <NavItem
      items={navItems}
      currentPath={currentPath}
      currentNavPath={currentNavPath}
      base={base}
      localePrefix={localePrefix}
      currentL3Path={currentL3Path}
      ariaLabel={t("sidebar.docsAriaLabel", locale)}
    />
  </div>
</aside>

<style>
  /* SB1-SB6, SH1-SH2: Matches mockup.html L162-210 exactly */
  .doc-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: var(--sidebar-width);
    background: var(--color-bg-tertiary);
    border-right: var(--border-width) solid var(--color-border);
    overflow: hidden;
    z-index: var(--z-sidebar);
  }
  .sidebar-inner {
    padding: var(--space-4) var(--space-4) var(--space-6);
    overflow-y: auto;
    height: 100%;
  }
  /* Sidebar home link */
  .sidebar-home {
    display: block;
    font-family: var(--font-heading);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-lg);
    color: var(--color-primary);
    padding: var(--space-2) 0;
    margin-bottom: var(--space-4);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .sidebar-home:hover {
    color: var(--color-link);
    text-decoration: none;
  }

  /* Responsive: <1280px — sidebar becomes drawer (including tablet range) */
  @media (max-width: 1279px) {
    .doc-sidebar {
      transform: translateX(-100%);
      transition: transform var(--transition-slow);
      z-index: var(--z-sidebar);
    }
    .doc-sidebar.is-open {
      transform: translateX(0);
    }
  }
</style>
