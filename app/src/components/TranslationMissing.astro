---
import { t, type Locale } from "@i18n/index";
import { canonicalizeSlug } from "@utils/collections";

interface Props {
  locale: Locale;
  zhSlug: string;
}

const { locale, zhSlug } = Astro.props;
const base = import.meta.env.BASE_URL;
// Point the user at the canonical zh URL (`/foo` not `/foo/index`).
const zhHref = `${base}${canonicalizeSlug(zhSlug)}`;
const homeHref = `${base}ja/`;
---

<section class="translation-missing">
  <h1 class="tm-title">{t("fallback.notTranslatedTitle", locale)}</h1>
  <p class="tm-desc">{t("fallback.notTranslatedDesc", locale)}</p>
  <div class="tm-actions">
    <a class="btn" href={zhHref}>{t("fallback.viewZhVersion", locale)}</a>
    <a class="btn btn--secondary" href={homeHref}>
      {t("fallback.returnHome", locale)}
    </a>
  </div>
</section>

<style>
  /* Fill the remaining viewport below header + main padding. */
  .translation-missing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* Desktop: main pad-top(header-height + space-8) + main pad-bottom(space-8) */
    height: calc(
      100vh - var(--header-height) - var(--space-8) - var(--space-8)
    );
    height: calc(
      100dvh - var(--header-height) - var(--space-8) - var(--space-8)
    );
    text-align: center;
    gap: var(--space-4);
  }

  @media (max-width: 1279px) {
    .translation-missing {
      /* Drawer mode (<1280): no fixed header; main pad(space-12 + space-8) */
      height: calc(100vh - var(--space-12) - var(--space-8));
      height: calc(100dvh - var(--space-12) - var(--space-8));
    }
  }

  @media (max-width: 767px) {
    .translation-missing {
      /* Mobile: main pad(space-8 + space-6) */
      height: calc(100vh - var(--space-8) - var(--space-6));
      height: calc(100dvh - var(--space-8) - var(--space-6));
    }
  }
  .tm-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    color: var(--color-primary);
    letter-spacing: 0.05em;
  }
  .tm-desc {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 520px;
  }
  .tm-actions {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
