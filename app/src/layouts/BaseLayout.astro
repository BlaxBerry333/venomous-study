---
import { ClientRouter } from "astro:transitions";
import { site } from "@utils/site";
import { DEFAULT_LEGION, LEGION_STORAGE_KEY } from "@utils/legions";
import {
  getLocaleFromUrl,
  localeToHtmlLang,
  t,
  type Locale,
} from "@i18n/index";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url);
const htmlLang = localeToHtmlLang[locale];
const siteName = t("site.name", locale);
const localizedSiteDescription = t("site.description", locale);
const { title, description = localizedSiteDescription } = Astro.props;
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const skipToContentLabel = t("nav.skipToContent", locale);

import "@styles/index.css";
---

<html lang={htmlLang} data-legion={DEFAULT_LEGION}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0d0c0a" />
    <link
      id="favicon"
      rel="icon"
      type="image/avif"
      href={import.meta.env.BASE_URL + "favicon.avif"}
    />
    <link
      id="apple-touch-icon"
      rel="apple-touch-icon"
      href={import.meta.env.BASE_URL + "favicon.avif"}
    />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />

    <!-- Apply saved legion theme + sync favicon before/after each navigation. -->
    <script
      is:inline
      define:vars={{
        DEFAULT_LEGION,
        LEGION_STORAGE_KEY,
        BASE_URL: import.meta.env.BASE_URL,
      }}
    >
      function legionLogoName(legion, era) {
        if (era === "heresy") {
          if (legion === "sons-of-horus") return "chaos--black-legion";
          return "chaos--" + legion;
        }
        return "imperial--" + legion;
      }
      function applySavedLegion() {
        try {
          const saved = JSON.parse(
            localStorage.getItem(LEGION_STORAGE_KEY) || "{}",
          );
          const legion = saved.legion || DEFAULT_LEGION;
          const era = (saved.eras && saved.eras[legion]) || "crusade";
          const root = document.documentElement;
          root.setAttribute("data-legion", legion);
          if (era === "heresy") {
            root.setAttribute("data-legion-era", "heresy");
          } else {
            root.removeAttribute("data-legion-era");
          }
          const iconUrl =
            BASE_URL + "legions/" + legionLogoName(legion, era) + ".avif";
          const fav = document.getElementById("favicon");
          const appleTouch = document.getElementById("apple-touch-icon");
          if (fav) fav.setAttribute("href", iconUrl);
          if (appleTouch) appleTouch.setAttribute("href", iconUrl);
        } catch {
          /* ignore */
        }
      }
      applySavedLegion();
      document.addEventListener("astro:after-swap", applySavedLegion);
      document.addEventListener("astro:page-load", applySavedLegion);
    </script>

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={htmlLang} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking webfont load: preload + swap-in to avoid blocking LCP. -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;600&family=Noto+Serif+SC:wght@400;600;700&family=Noto+Serif+JP:wght@400;600;700&display=swap"
    />
    <link
      id="fonts-stylesheet"
      rel="stylesheet"
      media="print"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;600&family=Noto+Serif+SC:wght@400;600;700&family=Noto+Serif+JP:wght@400;600;700&display=swap"
    />
    <script is:inline>
      // Swap fonts stylesheet media="print" -> "all" once it's loaded, so
      // the request is non-render-blocking while still applied for screen.
      {
        const el = document.getElementById("fonts-stylesheet");
        if (el)
          el.addEventListener("load", () => {
            el.media = "all";
          });
      }
    </script>
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;600&family=Noto+Serif+SC:wght@400;600;700&family=Noto+Serif+JP:wght@400;600;700&display=swap"
      />
    </noscript>
  </head>
  <body>
    <a href="#main-content" class="visually-hidden">{skipToContentLabel}</a>
    <slot />
  </body>
</html>
